    })
    if cfg["manager"].get("notify_macos", True):
        _macos_notify(f"Cursor Manager: {args.worker} 需决策", args.reason[:200])
    print(json.dumps({"ok": True, "escalated": args.worker, "reason": args.reason[:200]}, ensure_ascii=False))
    return 0


def cmd_rules(args):
    cfg = _load_cfg()
    worker = _find_worker(cfg, args.worker)
    for p in worker["rules_paths"]:
        path = _resolve_tool_path(p)
        print(f"\n========== {path} ==========\n")
