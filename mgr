#!/usr/bin/env python3
"""
manager-cli (mgr): codex-only atomic operations for the manager LLM (architecture Y).

设计原则：
  - 每个命令输出 well-formatted text 或 JSON，方便 LLM 读
  - 错误信息明确（"no_active_run" / "worktree_missing" / 等）
  - 不暴露 API key、不做策略判断（策略由 Manager LLM 决定）
  - 后端唯一：codex CLI。cursor-agent 已彻底从 in-loop 中移除。

子命令（核心）：
  mgr workers                     列出所有 worker
  mgr status <worker>             worker 当前 run 状态 + 上下文
  mgr commits <worker> [-n N]     worker branch 的最近 N 条 commit
  mgr diff <worker>               worker branch 相对 base 的 git diff
  mgr output <worker> [--max N]   worker 当前 / 最近一次 run 的 stdout 末尾
  mgr start <worker> -p "<prompt>"  fork 一个新 codex exec run
  mgr cancel <worker> [-r reason]   杀当前 active run（process group）
  mgr escalate <worker> -r "<reason>"  写 escalations.jsonl + macOS 通知
  mgr rules <worker>              打印 worker 的 hard rules
  mgr log -n N [--worker W]       看 mgr 命令的事件流
  mgr escalations                 看待人决策的 escalation
  mgr audit <worker>              看某 worker 的 manager tick audit log
  mgr mark-processed <worker> --run-id ID --verdict V --summary S   决策完调，更新 state

子命令（autoresearch sub-agents, v2 2026-05+）：
  mgr review-sim <worker>         NeurIPS reviewer-sim 跑一遍 worker 当前 diff
                                  （独立 codex --profile，跨 API 模型对抗）
  mgr lit-review <worker>         Semantic Scholar 验证 .bib + 推荐 must-cite
  mgr sentinel-tick               跑 sentinel watchdog 一次（cron 触发）
  mgr backend-test <worker>       烟测 codex CLI 健康
"""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
import time
import tomllib
from pathlib import Path

ROOT = Path(__file__).parent.resolve()
sys.path.insert(0, str(ROOT))

from lib.codex_worker import CodexWorker
from lib.state import AgentRegistry, JsonlLog, expand


CONFIG_PATH = ROOT / "config.toml"


def _make_codex_worker(cfg: dict, worker_id: str) -> CodexWorker:
    """Construct a CodexWorker for ``worker_id`` from config.

    ``[worker].backend`` defaults to "codex"; any other value is rejected
    early to make the codex-only invariant a hard guarantee at load time.
    """
    worker_cfg = cfg.get("worker", {}) or {}
    backend = (worker_cfg.get("backend") or "codex").strip().lower()
    if backend != "codex":
        sys.exit(
            f"[worker].backend = {backend!r} 不再支持；只剩 codex"
            f"（cursor-agent 已彻底从 in-loop 中移除）"
        )
    return CodexWorker(
        worker_id=worker_id,
        cli_path=worker_cfg.get("cli_path", "codex"),
        profile=worker_cfg.get("profile", "high"),
    )


def _resolve_tool_path(raw: str | Path) -> Path:
    p = expand(raw)
    return p if p.is_absolute() else (ROOT / p)


def _load_cfg() -> dict:
    if not CONFIG_PATH.exists():
        sys.exit(f"找不到 {CONFIG_PATH}（先 cp config.example.toml config.toml）")
    with open(CONFIG_PATH, "rb") as f:
        return tomllib.load(f)


def _find_worker(cfg: dict, worker_id: str) -> dict:
    for w in cfg["workers"]:
        if w["id"] == worker_id:
            return w
    sys.exit(f"未知 worker: {worker_id}（可用: {[w['id'] for w in cfg['workers']]}）")


def _make_worker(cfg: dict, worker_id: str) -> CodexWorker:
    """Create a CodexWorker (codex is the only supported backend)."""
    return _make_codex_worker(cfg, worker_id)


def _registry() -> AgentRegistry:
    """旧 registry，保留 last_processed_run_id / last_seen_commit / consecutive_restarts。"""
    return AgentRegistry(ROOT / "state" / "agents.json")


def _log() -> JsonlLog:
    cfg = _load_cfg()
    return JsonlLog(_resolve_tool_path(cfg["manager"]["log_path"]))


def _escalations() -> JsonlLog:
    cfg = _load_cfg()
    return JsonlLog(_resolve_tool_path(cfg["manager"]["escalations_path"]))


def _macos_notify(title: str, msg: str):
    try:
        subprocess.run(
            ["osascript", "-e", f'display notification "{msg}" with title "{title}"'],
            check=False,
            timeout=5,
        )
    except Exception:
        pass


def _git(*args, cwd, check: bool = True) -> str:
    proc = subprocess.run(
        ["git", *args],
        cwd=str(cwd),
        capture_output=True,
        text=True,
        timeout=60,
    )
    if check and proc.returncode != 0:
        raise RuntimeError(f"git {' '.join(args)} (cwd={cwd}) failed:\n{proc.stderr.strip()}")
    return proc.stdout


# ---------- 命令实现 ----------

def cmd_workers(args):
    cfg = _load_cfg()
    print(f"{'worker_id':<12} {'enabled':<8} {'worktree_path'}")
    print("-" * 90)
    for w in cfg["workers"]:
        lw = _make_worker(cfg, w["id"])
        wt = lw.worktree_path or "(未 bootstrap)"
        print(f"{w['id']:<12} {str(w.get('enabled', True)):<8} {wt}")
        print(f"             label: {w['label']}")
        if lw.branch:
            print(f"             branch: {lw.branch}")
        if lw.session_id:
            print(f"             codex_session_id: {lw.session_id}")


def cmd_status(args):
    cfg = _load_cfg()
    worker = _find_worker(cfg, args.worker)
    lw = _make_worker(cfg, args.worker)
    entry = _registry().get(args.worker) or {}

    out: dict = lw.to_dict()
    out["label"] = worker["label"]
    out["last_processed_run_id"] = entry.get("last_processed_run_id")
    out["last_seen_commit"] = entry.get("last_seen_commit")
    out["consecutive_restarts"] = entry.get("consecutive_restarts", 0)
    out["last_review"] = entry.get("last_review")

    # 加 git 状态（worker 在不在写东西）
    if lw.worktree_path and Path(lw.worktree_path).exists():
        try:
            head = _git("rev-parse", "HEAD", cwd=lw.worktree_path).strip()
            status = _git("status", "--porcelain", cwd=lw.worktree_path).strip()
            out["worktree_head"] = head
            out["worktree_dirty"] = bool(status)
            out["worktree_status_lines"] = status.splitlines()[:20]
        except Exception as e:
            out["git_error"] = str(e)
    else:
        out["worktree_missing"] = True

    print(json.dumps(out, ensure_ascii=False, indent=2, default=str))
    return 0


def cmd_commits(args):
    cfg = _load_cfg()
    worker = _find_worker(cfg, args.worker)
    lw = _make_worker(cfg, args.worker)
    if not lw.worktree_path:
        print(json.dumps({"error": "worktree_missing", "hint": "先 ./bootstrap.sh"}))
        return 1

    base = cfg["worker"].get("worktree_base", "paper/neurips2026-draft")
    last = None if args.all else (_registry().get(args.worker) or {}).get("last_seen_commit")

    try:
        if last:
            range_spec = f"{last}..HEAD"
        else:
            range_spec = f"{base}..HEAD"

        raw = _git(
            "log", "--reverse", "-n", str(args.n),
            "--pretty=format:%H%x1f%an%x1f%ai%x1f%s%x1f%b%x1e",
            range_spec,
            cwd=lw.worktree_path, check=False,
        )
        commits = []
        for chunk in raw.split("\x1e"):
            chunk = chunk.strip()
            if not chunk:
                continue
            parts = chunk.split("\x1f")
            if len(parts) < 5:
                parts += [""] * (5 - len(parts))
            commits.append({
                "hash": parts[0],
                "author": parts[1],
                "ai_date": parts[2],
                "subject": parts[3],
                "body": parts[4].strip(),
            })

        head = _git("rev-parse", "HEAD", cwd=lw.worktree_path).strip()
        out = {
            "worker_id": args.worker,
            "branch": lw.branch,
            "base": base,
            "since": last or f"(diverged from {base})",
            "head": head,
            "commits": commits,
        }
    except Exception as e:
        out = {"worker_id": args.worker, "error": "git_failed", "detail": str(e)}

    print(json.dumps(out, ensure_ascii=False, indent=2))
    return 0


def cmd_diff(args):
    cfg = _load_cfg()
    worker = _find_worker(cfg, args.worker)
    lw = _make_worker(cfg, args.worker)
    if not lw.worktree_path:
        print(json.dumps({"error": "worktree_missing"}))
        return 1
    base = cfg["worker"].get("worktree_base", "paper/neurips2026-draft")
    last = None if args.all else (_registry().get(args.worker) or {}).get("last_seen_commit")
    base_ref = last or base

    subdir = worker.get("subdir")
    try:
        stat_args = ["diff", "--stat", base_ref, "HEAD"]
        if subdir:
            stat_args += ["--", subdir]
        stat = _git(*stat_args, cwd=lw.worktree_path, check=False)

        diff_args = ["diff", base_ref, "HEAD"]
        if subdir:
            diff_args += ["--", subdir]
        full = _git(*diff_args, cwd=lw.worktree_path, check=False)

        if len(full) > args.max_chars:
            full = full[:args.max_chars] + f"\n\n[truncated {len(full) - args.max_chars} chars]"
        print(f"=== diff stat ({base_ref}..HEAD) ===\n{stat}")
        print(f"=== diff (truncated to {args.max_chars} chars) ===\n{full}")
    except Exception as e:
        print(json.dumps({"error": "git_failed", "detail": str(e)}))
        return 1
    return 0


def cmd_output(args):
    """读 worker 当前 / 最近一次 run 的 stdout 末尾。"""
    cfg = _load_cfg()
    lw = _make_worker(cfg, args.worker)
    text = lw.read_output(max_chars=args.max_chars)
    print(text)
    return 0


def cmd_start(args):
    cfg = _load_cfg()
    worker = _find_worker(cfg, args.worker)
    lw = _make_worker(cfg, args.worker)
    if not lw.worktree_path:
        print(json.dumps({"error": "worktree_missing", "hint": "先 ./bootstrap.sh"}))
        return 1

    timeout = args.timeout or cfg["worker"].get("default_timeout_seconds", 1800)

    try:
        info = lw.start(prompt=args.prompt, timeout_seconds=timeout)
    except RuntimeError as e:
        print(json.dumps({"error": "start_failed", "detail": str(e)}))
        return 2

    _log().append({
        "event": "manager_start_run",
        "worker_id": args.worker,
        "run_id": info.id,
        "pid": info.pid,
        "prompt_preview": args.prompt[:300],
    })
    print(json.dumps({
        "ok": True,
        "run_id": info.id,
        "pid": info.pid,
        "started_at": info.started_at,
        "output_path": info.output_path,
    }, ensure_ascii=False, indent=2))
    return 0


def cmd_cancel(args):
    cfg = _load_cfg()
    lw = _make_worker(cfg, args.worker)
    cur = lw.get_run()
    if not cur or not cur.is_active:
        print(json.dumps({"error": "no_active_run"}))
        return 1
    ok = lw.cancel()
    _log().append({
        "event": "manager_cancel_run",
        "worker_id": args.worker,
        "run_id": cur.id,
        "pid": cur.pid,
        "reason": args.reason or "(no reason)",
    })
    print(json.dumps({"ok": ok, "cancelled_run_id": cur.id, "cancelled_pid": cur.pid}, ensure_ascii=False))
    return 0


def cmd_escalate(args):
    cfg = _load_cfg()
    worker = _find_worker(cfg, args.worker)
    _escalations().append({
        "worker_id": args.worker,
        "label": worker["label"],
        "reason": args.reason,
        "raised_by": "manager_llm",
    })
    _log().append({
        "event": "manager_escalation",
        "worker_id": args.worker,
