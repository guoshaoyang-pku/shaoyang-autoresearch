def cmd_escalations(args):
    items = _escalations().tail(args.n)
    if args.worker:
        items = [it for it in items if it.get("worker_id") == args.worker]
    if not items:
        print("（无 escalation）")
        return 0
    for it in items:
        print(f"[{it.get('iso','')}] {it.get('worker_id','?')}: {it.get('reason','')}")
