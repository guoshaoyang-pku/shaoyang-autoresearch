def cmd_audit(args):
    audit_path = ROOT / "state" / "manager_audits" / f"{args.worker}.jsonl"
    if not audit_path.exists():
        print(f"无 audit 文件: {audit_path}")
        return 1
    lines = audit_path.read_text().splitlines()[-args.n:]
    for line in lines:
        try:
            d = json.loads(line)
            print(f"[{d.get('tick_at','')}] {d.get('action','?'):<14} {d.get('summary','')}")
        except Exception:
            print(line)
    return 0


def _read_diff_for_worker(cfg: dict, worker_id: str, base_ref: str | None = None, max_chars: int = 16000) -> tuple[str, list[dict], str]:
    """Helper: returns (full_diff, commits_list, head_sha) for the worker.

    Used by review-sim. Mirrors cmd_diff + cmd_commits but in-process, not stdout.
    """
    worker = _find_worker(cfg, worker_id)
    lw = _make_worker(cfg, worker_id)
    if not lw.worktree_path:
        raise RuntimeError("worktree_missing; run ./bootstrap.sh first")

    base = base_ref or cfg["worker"].get("worktree_base", "paper/neurips2026-draft")
    subdir = worker.get("subdir")
    head = _git("rev-parse", "HEAD", cwd=lw.worktree_path).strip()

    diff_args = ["diff", base, "HEAD"]
    if subdir:
        diff_args += ["--", subdir]
    full = _git(*diff_args, cwd=lw.worktree_path, check=False)
    if len(full) > max_chars:
        full = full[:max_chars] + f"\n\n[truncated {len(full) - max_chars} chars]"

    raw = _git(
        "log", "--reverse", "-n", "20",
        "--pretty=format:%H%x1f%an%x1f%ai%x1f%s%x1f%b%x1e",
        f"{base}..HEAD",
        cwd=lw.worktree_path, check=False,
    )
    commits = []
    for chunk in raw.split("\x1e"):
        chunk = chunk.strip()
        if not chunk:
            continue
        parts = chunk.split("\x1f")
        if len(parts) < 5:
            parts += [""] * (5 - len(parts))
        commits.append({"hash": parts[0], "author": parts[1], "ai_date": parts[2], "subject": parts[3], "body": parts[4].strip()})

    return full, commits, head


def cmd_review_sim(args):
    """Run NeurIPS reviewer-sim on the worker's current diff vs base.

    Writes ``state/reviewer_sim/<worker>/<run_id>.md`` and prints the path.
    """
    cfg = _load_cfg()
    rs_cfg = cfg.get("reviewer_sim") or {}
    if not rs_cfg:
        print(json.dumps({"error": "reviewer_sim_not_configured", "hint": "add [reviewer_sim] section to config.toml"}))
        return 1

    try:
        full_diff, commits, head = _read_diff_for_worker(cfg, args.worker, base_ref=args.against)
    except RuntimeError as e:
        print(json.dumps({"error": str(e)}))
        return 1

    if not full_diff.strip():
        print(json.dumps({"warn": "empty_diff", "head": head, "base": args.against or cfg["worker"].get("worktree_base")}))
        return 0

    from lib.reviewer_sim import ReviewerSim, StubReviewerSim

    backend = (rs_cfg.get("backend") or "codex").strip().lower()
    if backend not in {"codex", "stub"}:
        print(json.dumps({
            "error": "unsupported_backend",
            "backend": backend,
            "hint": "[reviewer_sim].backend must be 'codex' or 'stub' (cursor-agent removed)",
        }))
        return 1

    if backend == "stub":
        sim = StubReviewerSim()
        backend_label = "stub"
    else:
        sim = ReviewerSim(
            cli_path=rs_cfg.get("cli_path", "codex"),
            profile=rs_cfg.get("profile", "reviewer_high"),
            prompt_path=_resolve_tool_path(rs_cfg.get("prompt_path", "prompts/reviewer_sim_neurips.md")),
            timeout_seconds=int(rs_cfg.get("timeout_seconds", 600)),
        )
        backend_label = f"codex/{rs_cfg.get('profile','reviewer_high')}"

    worker = _find_worker(cfg, args.worker)
    extra_context = {"hard_rules_paths": worker.get("rules_paths", []), "section_focus": args.focus} if args.focus else None
    report = sim.review(
        worker_label=worker["label"],
        target_diff=full_diff,
        target_commits=commits,
        worker_run_output="",
        extra_context=extra_context,
    )

    run_id = f"{int(time.time())}-{head[:8]}"
    out_dir = ROOT / "state" / "reviewer_sim" / args.worker
    out_dir.mkdir(parents=True, exist_ok=True)
    out_path = out_dir / f"{run_id}.md"
    md = (
        f"# NeurIPS Reviewer Sim — {args.worker} {run_id}\n\n"
        + report.to_markdown()
        + f"\n\n## Provenance\n- diff: {args.against or cfg['worker'].get('worktree_base')}..{head}\n"
        + f"- commits: {len(commits)}\n- backend: {backend_label}\n"
    )
    out_path.write_text(md, encoding="utf-8")

    _log().append({
        "event": "manager_review_sim",
        "worker_id": args.worker,
        "head": head,
        "overall_score": report.overall_score,
        "n_concerns": len(report.concerns),
        "report_path": str(out_path),
    })

    print(json.dumps({
        "ok": True,
        "report_path": str(out_path),
        "overall_score": report.overall_score,
        "confidence": report.confidence,
        "n_strengths": len(report.strengths),
        "n_concerns": len(report.concerns),
        "n_requested_changes": len(report.requested_changes),
        "summary": report.summary,
    }, ensure_ascii=False, indent=2))
    return 0


def cmd_lit_review(args):
    """Verify worker's .bib against Semantic Scholar + suggest must-cites.

    Writes ``state/lit_review/<worker>/<run_id>.json`` plus .md summary.
    """
    cfg = _load_cfg()
    lr_cfg = cfg.get("lit_review") or {}

    worker = _find_worker(cfg, args.worker)
    lw = _make_worker(cfg, args.worker)
    if not lw.worktree_path:
        print(json.dumps({"error": "worktree_missing"}))
        return 1

    bib_path = args.bib or lr_cfg.get("default_bib_path")
    if not bib_path:
        print(json.dumps({"error": "bib_path_required", "hint": "pass --bib path/to/refs.bib or set [lit_review].default_bib_path in config.toml"}))
        return 1
    bib_full = Path(lw.worktree_path) / bib_path if not Path(bib_path).is_absolute() else Path(bib_path)
    if not bib_full.exists():
        print(json.dumps({"error": "bib_not_found", "tried": str(bib_full)}))
        return 1

    keywords = []
    if args.keywords:
        keywords = [k.strip() for k in args.keywords.split(",") if k.strip()]
    elif lr_cfg.get("default_keywords"):
        keywords = list(lr_cfg["default_keywords"])

    from lib.lit_review import LitReview, StubLitReview, SemanticScholarClient
    from lib.secrets import get_semantic_scholar_api_key, load_keys

    if args.stub or lr_cfg.get("backend") == "stub":
        rev = StubLitReview()
    else:
        ss_key = lr_cfg.get("semantic_scholar_api_key") or None
        if not ss_key:
            ss_key = get_semantic_scholar_api_key(load_keys())
        client = SemanticScholarClient(
            api_key=ss_key,
            rate_limit_rps=float(lr_cfg.get("rate_limit_rps", 1.0)),
        )
        rev = LitReview(client=client)

    report = rev.run_full(bib_path=bib_full, keywords=keywords or None)

    run_id = f"{int(time.time())}"
    out_dir = ROOT / "state" / "lit_review" / args.worker
    out_dir.mkdir(parents=True, exist_ok=True)
    json_path = out_dir / f"{run_id}.json"
    md_path = out_dir / f"{run_id}.md"

    json_path.write_text(json.dumps(report.to_dict(), ensure_ascii=False, indent=2), encoding="utf-8")
    md_path.write_text(report.to_markdown_summary(), encoding="utf-8")

    _log().append({
        "event": "manager_lit_review",
        "worker_id": args.worker,
        "bib_path": str(bib_full),
        "n_entries_total": report.n_entries_total,
        "n_verified": report.n_verified,
        "n_unverified": report.n_unverified,
        "n_must_cite_suggestions": len(report.must_cite_suggestions),
        "report_json": str(json_path),
    })

    print(json.dumps({
        "ok": True,
        "report_json": str(json_path),
        "report_md": str(md_path),
        "n_entries_total": report.n_entries_total,
        "n_verified": report.n_verified,
        "n_unverified": report.n_unverified,
        "n_must_cite_suggestions": len(report.must_cite_suggestions),
    }, ensure_ascii=False, indent=2))
    return 0


def cmd_sentinel_tick(args):
    """Run sentinel watchdog one tick. Pass-through to sentinel.py."""
    sentinel_py = ROOT / "sentinel.py"
    cmd = [sys.executable, str(sentinel_py)]
    if args.dry_run:
        cmd.append("--dry-run")

    try:
        proc = subprocess.run(cmd, cwd=str(ROOT), capture_output=True, text=True, timeout=120)
    except subprocess.TimeoutExpired:
        print(json.dumps({"error": "sentinel_timeout"}))
        return 1

    print(proc.stdout, end="")
    if proc.stderr:
        print("--- stderr ---\n" + proc.stderr, file=sys.stderr)

    _log().append({
        "event": "manager_sentinel_tick",
        "exit_code": proc.returncode,
        "dry_run": bool(args.dry_run),
    })
    return proc.returncode


def cmd_backend_test(args):
    """Smoke-test the codex CLI by running a trivial prompt and reading the output.

    Does NOT use ``codex exec resume`` / persistent session. Just verifies
    the CLI is reachable and roundtrips a single token. cursor-agent is no
    longer a supported backend; ``[worker].backend`` must be ``codex``.
    """
    cfg = _load_cfg()
    worker_cfg = cfg.get("worker", {}) or {}
    backend = (worker_cfg.get("backend") or "codex").strip().lower()

    if backend != "codex":
        print(json.dumps({
            "ok": False,
            "error": "unsupported_backend",
            "backend": backend,
            "hint": "[worker].backend must be 'codex' (cursor-agent removed)",
        }, ensure_ascii=False, indent=2))
        return 2

    cli_path = worker_cfg.get("cli_path", "codex")
    profile = worker_cfg.get("profile", "high")
    bash_cmd = (
        f"{cli_path} exec --skip-git-repo-check --color never --profile {profile} "
        f'"reply with the single word OK and nothing else" < /dev/null'
    )
    wrapper = ["/bin/bash", "-c", bash_cmd]
    timeout = 90

    try:
        proc = subprocess.run(wrapper, capture_output=True, text=True, timeout=timeout)
    except subprocess.TimeoutExpired:
        print(json.dumps({"ok": False, "error": "timeout", "backend": backend, "timeout_seconds": timeout}))
        return 1
    except FileNotFoundError as e:
        print(json.dumps({"ok": False, "error": "cli_not_found", "backend": backend, "detail": str(e)}))
        return 2

    has_ok = "OK" in (proc.stdout or "")
    out_preview = (proc.stdout or "").strip()[-400:]

    result = {
        "ok": proc.returncode == 0 and has_ok,
        "backend": backend,
        "profile": profile,
        "exit_code": proc.returncode,
        "saw_OK_token": has_ok,
        "output_preview": out_preview,
    }
    print(json.dumps(result, ensure_ascii=False, indent=2))
    return 0 if result["ok"] else 3


def cmd_mark_processed(args):
    cfg = _load_cfg()
    worker = _find_worker(cfg, args.worker)
    lw = _make_worker(cfg, args.worker)
    reg = _registry()
    entry = reg.get(args.worker) or {}

    head = None
    if lw.worktree_path:
        try:
            head = _git("rev-parse", "HEAD", cwd=lw.worktree_path).strip()
        except Exception:
            head = entry.get("last_seen_commit") or "unknown"

    reg.update(
        args.worker,
        last_processed_run_id=args.run_id,
        last_seen_commit=head or "unknown",
        last_review={
            "verdict": args.verdict,
            "summary": args.summary or "",
            "ts": time.time(),
        },
    )
    if args.verdict == "continue":
        reg.update(args.worker, consecutive_restarts=0)
    elif args.verdict == "cancel_restart":
        cur = (entry.get("consecutive_restarts") or 0) + 1
        reg.update(args.worker, consecutive_restarts=cur)
    print(json.dumps({"ok": True, "head": head, "verdict": args.verdict}, ensure_ascii=False))
    return 0


